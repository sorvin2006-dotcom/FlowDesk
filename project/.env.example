# ============================================================
#  Настройки Supabase
#  Скопируйте этот файл в .env и заполните своими значениями
#  Значения берите из: Supabase Dashboard → Settings → API
# ============================================================

# URL вашего проекта Supabase
# Пример: https://abcdefghijklm.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co

# Anon (public) ключ — для клиентского приложения
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ============================================================
#  Дополнительно (необязательно для запуска, нужно для функций)
#  Эти ключи добавляются в Supabase Dashboard → Edge Functions → Secrets
# ============================================================

# AI-ассистент (Groq) — получить ключ: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Платежи (ЮKassa) — https://yookassa.ru/
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
